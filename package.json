{
  "name": "lcec",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:11ty\" \"npm run dev:sass\" \"npm run dev:js\"",
    "dev:11ty": "eleventy --serve --incremental",
    "dev:sass": "sass src/scss/main.scss dist/css/main.css --watch --style=expanded --source-map",
    "dev:js": "node build/js.js --watch",
    "build": "npm run build:clean && npm run build:11ty && npm run build:sass && npm run build:js",
    "build:clean": "node build/clean.js",
    "build:11ty": "eleventy",
    "build:sass": "sass src/scss/main.scss dist/css/main.css --style=compressed --no-source-map",
    "build:js": "node build/js.js"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.25.0",
    "html-minifier-terser": "^7.2.0",
    "sass": "^1.80.0"
  }
}
