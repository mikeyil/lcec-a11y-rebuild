---
layout: base.njk
---
<section class="page-title">
  <div class="container">
    <h1 class="page-title__heading">{{ page_title.heading }}</h1>
    <p class="page-title__subheading">{{ page_title.subheading }}</p>
  </div>
</section>

<section class="section section--green">
  <div class="container">
    <div class="why-content">
      <img src="{{ '/img/laura-cantagallo.webp' | url }}" alt="Laura Cantagallo, founder of LC Education Consulting" class="why-content__photo" width="400" height="400" />
      <div class="why-content__text">
        <p class="why-content__subheading">{{ page_title.subheading }}</p>
        <p class="why-content__body">{{ body }}</p>
      </div>
    </div>
  </div>
</section>

<section class="section section--dark">
  <div class="container">
    <div class="credentials-layout">
      <div class="credentials-layout__text">
        <h2 class="section-heading text-white">{{ credentials_heading }}</h2>
        <ul class="credentials-list">
          {% for item in credentials %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      <img src="{{ '/img/why-choose-us_career.webp' | url }}" alt="" class="credentials-layout__photo" aria-hidden="true" loading="lazy" />
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <h2 class="reviews-section__heading">What Clients Have to Say</h2>
    <blockquote class="quote-block">
      <p class="quote-block__text">{{ quote.text }}</p>
      <footer class="quote-block__attribution">&mdash; {{ quote.attribution }}</footer>
    </blockquote>
  </div>
</section>

<section class="section section--green">
  <div class="container">
    <div class="cta-block">
      <h2 class="cta-block__heading">{{ cta.heading }}</h2>
      <p class="cta-block__subheading">{{ cta.subheading }}</p>
      <a href="{{ cta.button_url }}" class="btn btn--primary" target="_blank" rel="noopener">{{ cta.button_text }}</a>
    </div>
  </div>
</section>
