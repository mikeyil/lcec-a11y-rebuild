---
layout: base.njk
---
<section class="section section--white section--flush-top section--flush-bottom">
  <div class="container">
    <h1 class="heading--section">{{ page_title.heading }}</h1>
    <div class="bio-layout">
      <img src="{{ '/img/about-laura-cantagallo.webp' | url }}" alt="Laura Cantagallo, founder of LC Education Consulting" class="bio-layout__photo" width="400" height="400" loading="lazy" />
      <div class="bio-layout__text">
        <h2 class="tagline">{{ page_title.subheading }}</h2>
        {% for paragraph in body %}
        <p class="bio-layout__body">{{ paragraph }}</p>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<div class="container bp-desktop-only">
  <hr class="divider" />
</div>

<section class="section section--white section--flush-top section--flush-bottom">
  <div class="container">
    <div class="credentials-layout">
      <div class="credentials-layout__text">
        <h2 class="detail-heading">{{ credentials_heading }}</h2>
        <ul class="credentials-list">
          {% for item in credentials %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      <img src="{{ '/img/about-career.webp' | url }}" alt="" class="credentials-layout__photo" aria-hidden="true" loading="lazy" />
    </div>
  </div>
</section>

{% set variant = "light" %}
{% set testimonial_heading = "What Clients Have to Say" %}
{% include "partials/testimonial.njk" %}

{% include "partials/social-section.njk" %}
