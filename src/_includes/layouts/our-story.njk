---
layout: base.njk
---
<section class="section section--blue">
  <div class="container">
    <div class="page-intro">
      <h1 class="page-intro__heading">{{ intro.heading }}</h1>
      {% for paragraph in intro.body %}
      <p>{{ paragraph }}</p>
      {% endfor %}
    </div>
  </div>
</section>

<section class="content-blocks section section--white section--flush-bottom">
  <div class="container">
    <h2 class="heading--section">{{ philosophy.heading }}</h2>
    <div class="content-blocks__grid">
      {% for block in philosophy.blocks %}
      <article class="content-blocks__block">
        <h3 class="content-blocks__block-heading">{{ block.heading }}</h3>
        <img src="{{ block.image | url }}" alt="" class="content-blocks__image" width="16" height="9" aria-hidden="true" loading="lazy">
        <p>{{ block.body }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

{% include "partials/social-section.njk" %}
