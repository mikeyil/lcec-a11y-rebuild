---
layout: base.njk
---
<section class="page-title">
  <div class="container">
    <h1 class="page-title__heading">{{ page_title.heading }}</h1>
  </div>
</section>

<section class="section section--blue">
  <div class="container">
    <div class="portfolio-intro">
      <h2 class="portfolio-intro__heading">{{ page_title.heading }}</h2>
      <p>{{ intro_body }}</p>
    </div>
  </div>
</section>

<section class="section section--dark">
  <div class="container">
    <h2 class="section-heading text-white">{{ projects_heading }}</h2>
    <ul class="portfolio-list">
      {% for project in projects %}
      <li class="portfolio-card">
        {% if project.image %}
        <img src="{{ project.image | url }}" alt="" class="portfolio-card__image" aria-hidden="true" loading="lazy" />
        {% endif %}
        <p class="portfolio-card__title">{{ project.title }}</p>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="section section--blue">
  <div class="container">
    <div class="cta-block">
      <h2 class="cta-block__heading">{{ cta.heading }}</h2>
      <p class="cta-block__subheading">{{ cta.subheading }}</p>
      <a href="{{ cta.button_url }}" class="btn btn--ghost" target="_blank" rel="noopener">{{ cta.button_text }}</a>
    </div>
  </div>
</section>
