---
layout: page-with-intro.njk
---
<section class="section section--white">
  <div class="container">
    <h2 class="detail-heading">Webinars and Training</h2>
    <div class="credentials-layout">
      <div class="credentials-layout__text">
        {% for training in trainings %}
        <h3 class="detail-subheading">{{ training.heading }}</h3>
        <p class="training-card__description">{{ training.description }}</p>
        {% endfor %}
      </div>
      <img src="{{ '/img/webinars-and-training.jpg' | url }}" alt="" class="credentials-layout__photo" aria-hidden="true" loading="lazy" />
    </div>
  </div>
</section>
