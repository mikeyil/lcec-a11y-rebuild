---
layout: base.njk
---
<section class="hero">
  <div class="container hero__inner">
    <figure class="hero__logo">
      <picture>
        <source srcset="{{ '/img/logo-lcec.webp' | url }}" type="image/webp" />
        <img src="{{ '/img/logo-lcec.jpg' | url }}" alt="LC Education Consulting Logo" width="548" height="548" fetchpriority="high" />
      </picture>
    </figure>
    <div class="hero__content">
      <p class="hero__eyebrow">{{ hero.eyebrow }}</p>
      <h1 class="hero__heading">{{ hero.heading }}</h1>
      <p class="hero__subheading">{{ hero.subheading }}</p>
      <div class="hero__actions">
        <a href="{{ hero.cta_primary_url or site.calendar_url }}" class="btn btn--primary" target="_blank" rel="noopener noreferrer">{{ hero.cta_primary_text }}</a>
        <a href="{{ hero.cta_secondary_url | url }}" class="btn btn--primary">{{ hero.cta_secondary_text }}</a>
      </div>
    </div>
  </div>
</section>

<section class="section section--blue">
  <div class="container">
    <div class="page-intro">
      <h2 class="page-intro__heading text-titlecase">{{ announcement.heading }}</h2>
      <p>{{ announcement.subheading | safe }}</p>
      <p>{{ announcement.body }}</p>
      <a href="{{ announcement.link_url }}" class="btn btn--ghost" target="_blank" rel="noopener noreferrer">{{ announcement.link_text }}</a>
    </div>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    <h2 class="section-lead text-center text-uppercase">{{ stats_heading }}</h2>
    <div class="stats-grid">
      {% for stat in stats %}
      <figure class="stat">
        <p class="stat__value">{{ stat.value }}</p>
        <figcaption class="stat__label">{{ stat.label }}</figcaption>
      </figure>
      {% endfor %}
    </div>
  </div>
</section>

{% set quote_short = true %}
{% include "partials/testimonial.njk" %}

{% include "partials/social-section.njk" %}
