---
layout: base.njk
---
<section class="page-title">
  <div class="container">
    <h1 class="page-title__heading">{{ page_title.heading }}</h1>
  </div>
</section>

<section class="section section--green">
  <div class="container">
    <p class="intro-section__body">{{ body1 }}</p>
    <p class="intro-section__body">{{ body2 }}</p>
  </div>
</section>

<section class="section section--dark">
  <div class="container text-center">
    <h2 class="section-heading text-white">{{ contact_block.heading }}</h2>
    <p><a href="{{ contact_block.phone_href }}" class="text-on-dark text-xl">{{ contact_block.phone }}</a></p>
    <p><a href="{{ contact_block.email_href }}" class="text-on-dark">{{ contact_block.email }}</a></p>
  </div>
</section>

<section class="section section--green">
  <div class="container">
    <div class="cta-block">
      <h2 class="cta-block__heading">{{ cta.heading }}</h2>
      <p class="cta-block__subheading">{{ cta.subheading }}</p>
      <a href="{{ cta.button_url }}" class="btn btn--primary" target="_blank" rel="noopener">{{ cta.button_text }}</a>
    </div>
  </div>
</section>
