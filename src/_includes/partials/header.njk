<header class="site-header container">
  <div class="header-inner">
    <div class="header-logo-row">
      <a href="{{ '/' | url }}" class="logo">
        <span class="logo__text">{{ site.name }}</span>
      </a>
      <div class="header-phone">
        <a href="{{ office.phone_href }}">{{ office.phone }}</a>
      </div>
    </div>
    <div class="header-nav-row">
      <nav class="nav" aria-label="Menu">
        <ul class="nav__list">
          {% for link in navigation.links %}
          <li class="nav__item">
            {% if link.dropdown %}
              <button class="nav__dropdown-btn" aria-expanded="false" aria-controls="{{ link.id }}">
                <span>{{ link.text }}</span>
                <svg viewBox="7.5 9.5 9 5" fill="currentColor" width="12" height="7" aria-hidden="true">
                  <polygon points="12,14 8,10 16,10"/>
                </svg>
              </button>
              <div id="{{ link.id }}" class="nav__dropdown">
                <ul class="nav__dropdown-list">
                  {% for child in link.children %}
                  <li class="nav__dropdown-item">
                    <a href="{{ child.url | url }}" class="nav__dropdown-link" {% if page.url == child.url %}aria-current="page"{% endif %}>
                      <span>{{ child.text }}</span>
                    </a>
                  </li>
                  {% endfor %}
                </ul>
              </div>
            {% elif link.external %}
              <a href="{{ link.url }}" class="nav__link" target="_blank" rel="noopener noreferrer">{{ link.text }}</a>
            {% else %}
              <a href="{{ link.url | url }}" class="nav__link" {% if page.url == link.url %}aria-current="page"{% endif %}>{{ link.text }}</a>
            {% endif %}
          </li>
          {% endfor %}
        </ul>
      </nav>
      <button class="mobile-nav-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menu">
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true">
          <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav-overlay" id="mobile-nav-overlay" aria-hidden="true"></div>

<nav class="mobile-nav" id="mobile-nav" aria-label="Menu" aria-hidden="true">
  <button class="mobile-nav__close" aria-label="Close Menu">
    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
      <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
    </svg>
  </button>
  <ul class="mobile-nav__list">
    {% for link in navigation.links %}
      {% if link.dropdown %}
        {% for child in link.children %}
        <li>
          <a href="{{ child.url | url }}" class="mobile-nav__link" {% if page.url == child.url %}aria-current="page"{% endif %}>{{ child.text }}</a>
        </li>
        {% endfor %}
      {% elif link.external %}
        <li>
          <a href="{{ link.url }}" class="mobile-nav__link" target="_blank" rel="noopener noreferrer">{{ link.text }}</a>
        </li>
      {% else %}
        <li>
          <a href="{{ link.url | url }}" class="mobile-nav__link" {% if page.url == link.url %}aria-current="page"{% endif %}>{{ link.text }}</a>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</nav>
