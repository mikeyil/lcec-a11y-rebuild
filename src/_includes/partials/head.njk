<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{% if title %}{{ title }} | {% endif %}LC Education Consulting</title>
<meta name="description" content="{% if description %}{{ description }}{% else %}Accessibility reviews, training, and digital accessibility support rooted in 16 years of special education experience.{% endif %}" />
<link rel="manifest" href="{{ '/manifest.webmanifest' | url }}" />
<link rel="icon" type="image/svg+xml" href="{{ '/images/favicon.svg' | url }}" />
<link rel="apple-touch-icon" sizes="180x180" href="{{ '/images/lc-logo.svg' | url }}" />
<meta property="og:site_name" content="LC Education Consulting" />
<meta property="og:title" content="{% if title %}{{ title }} | LC Education Consulting{% else %}LC Education Consulting{% endif %}" />
<meta property="og:description" content="{% if description %}{{ description }}{% else %}Accessibility reviews, training, and digital accessibility support rooted in 16 years of special education experience.{% endif %}" />
<meta property="og:image" content="{{ '/images/lc-logo.svg' | url }}" />
<meta name="twitter:card" content="summary" />
<meta name="theme-color" content="#556b2f" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,400;1,700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="{{ '/css/main.css' | url }}" />
