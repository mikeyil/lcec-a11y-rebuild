# Cache headers — supported by Netlify and Cloudflare Pages.
# GitHub Pages ignores this file; migrate hosts to activate.

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/img/*
  Cache-Control: public, max-age=31536000, immutable

/*
  Cache-Control: public, max-age=3600, must-revalidate
