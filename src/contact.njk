<section class="contact-form-section">
  <div class="container">
    <form class="contact-form" aria-live="polite" action="#" method="post">
      <h2 class="contact-form__heading">Let&rsquo;s Talk About Your Needs</h2>

      {# Honeypot — hidden from real users #}
      <input type="text" name="_app_id" autocomplete="off" tabindex="-1" value="" />

      <div class="form-field">
        <label class="form-label" for="org-name">Organization Name <span aria-hidden="true">*</span></label>
        <input class="form-input" type="text" id="org-name" name="org_name" required autocomplete="organization" />
      </div>

      <div class="form-field">
        <label class="form-label" for="your-name">Your Name <span aria-hidden="true">*</span></label>
        <input class="form-input" type="text" id="your-name" name="your_name" required autocomplete="name" />
      </div>

      <div class="form-field">
        <label class="form-label" for="email">Email <span aria-hidden="true">*</span></label>
        <input class="form-input" type="email" id="email" name="email" required autocomplete="email" />
      </div>

      <div class="form-field">
        <label class="form-label" for="phone">Phone Number <span aria-hidden="true">*</span></label>
        <input class="form-input" type="tel" id="phone" name="phone" required autocomplete="tel" />
      </div>

      <div class="form-field">
        <label class="form-label" for="location">Location (City/State) <span aria-hidden="true">*</span></label>
        <input class="form-input" type="text" id="location" name="location" required />
      </div>

      <div class="form-field">
        <label class="form-label" for="org-type">Type of Organization <span aria-hidden="true">*</span></label>
        <textarea class="form-textarea" id="org-type" name="org_type" rows="4" required placeholder="School District / Company / Nonprofit / Higher Ed / Other"></textarea>
      </div>

      <div class="form-field">
        <label class="form-label" for="service-interest">Service Interest <span aria-hidden="true">*</span></label>
        <textarea class="form-textarea" id="service-interest" name="service_interest" rows="4" required placeholder="Accessibility Evaluation / Website Remediation / Training &amp; Webinars / VPAT Writing / Other"></textarea>
      </div>

      <div class="form-field">
        <label class="form-label" for="description">Brief description of need <span aria-hidden="true">*</span></label>
        <textarea class="form-textarea" id="description" name="description" rows="4" required></textarea>
      </div>

      <div class="form-field">
        <label class="form-label" for="contact-method">Preferred Contact Method <span aria-hidden="true">*</span></label>
        <input class="form-input" type="text" id="contact-method" name="contact_method" required placeholder="Email / Phone / Either" />
      </div>

      <button type="submit" class="form-submit">Send</button>

      <p class="form-privacy">
        This site is protected by reCAPTCHA and the Google
        <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacy Policy</a>
        and
        <a href="https://policies.google.com/terms" target="_blank" rel="noopener">Terms of Service</a>
        apply.
      </p>
    </form>
  </div>
</section>

